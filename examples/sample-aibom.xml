  <components>
    <component type="machine-learning-model" bom-ref="whisper-large-v3">
      <name>whisper-large-v3</name>
      <version>20230314</version>
      <description>Whisper large-v3 is a pre-trained model for automatic speech recognition (ASR) and speech translation.</description>
      <supplier>
        <name>OpenAI</name>
        <url>https://openai.com</url>
      </supplier>
      <licenses>
        <license>
          <id>MIT</id>
        </license>
      </licenses>
      <modelCard>
        <modelParameters>
          <approach>
            <type>supervised</type>
          </approach>
          <task>Automatic Speech Recognition and Speech Translation</task>
          <architectureFamily>Transformer (Encoder-Decoder)</architectureFamily>
          <modelArchitecture>Transformer with multi-head attention encoder and autoregressive decoder</modelArchitecture>
          <datasets>
            <dataset>
              <type>dataset</type>
              <name>Whisper Training Data</name>
              <description>680,000 hours of multilingual and multitask weakly-supervised web audio data</description>
              <governance>
                <owners>
                  <owner>
                    <organization>
                      <name>OpenAI</name>
                    </organization>
                  </owner>
                </owners>
              </governance>
            </dataset>
          </datasets>
          <inputs>
            <input>
              <format>audio/wav</format>
            </input>
            <input>
              <format>audio/mp3</format>
            </input>
            <input>
              <format>audio/flac</format>
            </input>
          </inputs>
          <outputs>
            <output>
              <format>text/plain</format>
            </output>
          </outputs>
        </modelParameters>
        <quantitativeAnalysis>
          <performanceMetrics>
            <performanceMetric>
              <type>Word Error Rate (WER)</type>
              <value>4.2%</value>
              <description>Word error rate on LibriSpeech test-clean</description>
            </performanceMetric>
            <performanceMetric>
              <type>Word Error Rate (WER)</type>
              <value>8.4%</value>
              <description>Word error rate on LibriSpeech test-other</description>
            </performanceMetric>
          </performanceMetrics>
        </quantitativeAnalysis>
        <considerations>
          <technicalLimitations>
            <technicalLimitation>Performance varies across languages; lower-resource languages have higher error rates</technicalLimitation>
            <technicalLimitation>May hallucinate text for very noisy audio or non-speech audio</technicalLimitation>
            <technicalLimitation>Real-time processing may require GPU acceleration</technicalLimitation>
          </technicalLimitations>
          <ethicalConsiderations>
            <ethicalConsideration>
              <description>Model trained on web-scraped data which may contain biases</description>
            </ethicalConsideration>
            <ethicalConsideration>
              <description>Performance disparities across accents and dialects</description>
            </ethicalConsideration>
            <ethicalConsideration>
              <description>Potential for misuse in surveillance applications</description>
            </ethicalConsideration>
          </ethicalConsiderations>
        </considerations>
      </modelCard>
      <externalReferences>
        <reference type="website">
          <url>https://github.com/openai/whisper</url>
        </reference>
        <reference type="documentation">
          <url>https://arxiv.org/abs/2212.04356</url>
        </reference>
        <reference type="distribution">
          <url>https://huggingface.co/openai/whisper-large-v3</url>
        </reference>
      </externalReferences>
    </component>
