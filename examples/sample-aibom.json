      "modelCard": {
        "modelParameters": {
          "approach": {
            "type": "supervised"
          },
          "task": "Automatic Speech Recognition and Speech Translation",
          "architectureFamily": "Transformer (Encoder-Decoder)",
          "modelArchitecture": "Transformer with multi-head attention encoder and autoregressive decoder",
          "datasets": [
            {
              "type": "dataset",
              "name": "Whisper Training Data",
              "description": "680,000 hours of multilingual and multitask weakly-supervised web audio data",
              "governance": {
                "owners": [
                  {
                    "organization": {
                      "name": "OpenAI"
                    }
                  }
                ]
              }
            }
          ],
