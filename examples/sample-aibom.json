              "format": "audio/wav"
            },
            {
              "format": "audio/mp3"
            },
            {
              "format": "audio/flac"
            }
          ],
          "outputs": [
            {
              "format": "text/plain"
            }
          ]
        },
        "quantitativeAnalysis": {
          "performanceMetrics": [
            {
              "type": "Word Error Rate (WER)",
              "value": "4.2%",
              "description": "Word error rate on LibriSpeech test-clean"
            },
            {
              "type": "Word Error Rate (WER)",
              "value": "8.4%",
              "description": "Word error rate on LibriSpeech test-other"
            }
          ]
        },
        "considerations": {
          "technicalLimitations": [
            "Performance varies across languages; lower-resource languages have higher error rates",
            "May hallucinate text for very noisy audio or non-speech audio",
            "Real-time processing may require GPU acceleration"
          ],
          "ethicalConsiderations": [
            {
              "description": "Model trained on web-scraped data which may contain biases"
            },
            {
              "description": "Performance disparities across accents and dialects"
            },
            {
              "description": "Potential for misuse in surveillance applications"
            }
          ]
        }
